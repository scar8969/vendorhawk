# Database
DATABASE_URL=postgresql://user:password@localhost:5432/procureai
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI/LLM
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
QWEN_MODEL=qwen/qwen-3.6-plus

# App Settings
APP_ENV=development
BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
SECRET_KEY=your-secret-key-change-this-in-production

# Scraping
SCRAPER_USER_AGENT=ProcureAI/1.0
SCRAPER_RATE_LIMIT=2

# Monitoring (Optional)
SENTRY_DSN=https://your-sentry-dsn
ENABLE_DEBUG_LOGGING=true

# Storage (Supabase)
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1/object
SUPABASE_STORAGE_BUCKET=procureai-invoices

# Tesseract OCR
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_LANG=eng+hin

# Rate Limiting
RATE_LIMIT_FREE=10/minute
RATE_LIMIT_STANDARD=100/minute
RATE_LIMIT_ENTERPRISE=1000/minute

# Cache (Redis - Optional)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=86400  # 24 hours in seconds

# Background Tasks
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
